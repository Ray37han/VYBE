# ==========================================
# FIREBASE CONFIGURATION - PHONE OTP
# ==========================================
# Add these to your .env file to enable Firebase Phone Authentication

# Firebase Project Configuration
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ==========================================
# QUICK SETUP GUIDE (2 MINUTES)
# ==========================================

# Step 1: Create Firebase Project
# → Go to https://console.firebase.google.com
# → Click "Add project"
# → Name it "vybe-ecommerce" (or any name)
# → Continue through setup (disable Google Analytics if you want)

# Step 2: Enable Phone Authentication
# → In Firebase Console, go to "Authentication"
# → Click "Get Started"
# → Go to "Sign-in method" tab
# → Enable "Phone" provider
# → Click "Save"

# Step 3: Get Your Configuration
# → Go to Project Settings (gear icon)
# → Scroll down to "Your apps"
# → Click the web icon (</>)
# → Register app (name it "vybe-client")
# → Copy the firebaseConfig values

# Step 4: Add to .env File
# → Copy the values from Firebase Console
# → Paste them into your .env file with VITE_ prefix
# → Restart your dev server: npm run dev

# Example from Firebase Console:
# const firebaseConfig = {
#   apiKey: "AIzaSyC1234567890abcdefghijk",           ← Copy this
#   authDomain: "vybe-123456.firebaseapp.com",        ← Copy this
#   projectId: "vybe-123456",                          ← Copy this
#   storageBucket: "vybe-123456.appspot.com",         ← Copy this
#   messagingSenderId: "123456789012",                 ← Copy this
#   appId: "1:123456789012:web:abcd1234"              ← Copy this
# };

# ==========================================
# TESTING WITHOUT FIREBASE (OPTIONAL)
# ==========================================
# You can test the checkout form, cart, and Buy Now without Firebase
# Firebase is only needed for the actual OTP sending/verification
